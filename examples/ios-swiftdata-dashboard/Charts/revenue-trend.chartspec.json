{
  "specVersion": "1.1.0",
  "id": "example.ios.revenue.trend.v1",
  "metadata": {
    "name": "Revenue Trend",
    "description": "Thirty-day revenue trend loaded from SwiftData.",
    "tags": ["example", "ios", "swiftdata", "trend"],
    "status": "stable",
    "owners": ["chartcn-core"],
    "updatedAt": "2026-03-10"
  },
  "data": {
    "source": {
      "adapter": "swiftdata",
      "entity": "DailyRevenue",
      "sort": [
        { "field": "day", "direction": "asc" }
      ],
      "limit": 30
    },
    "dimensions": [
      { "key": "day", "type": "time", "label": "Day" }
    ],
    "measures": [
      { "key": "revenue", "type": "currency", "label": "Revenue", "currency": "USD" }
    ]
  },
  "visual": {
    "chartType": "line",
    "xField": "day",
    "series": [
      {
        "field": "revenue",
        "label": "Revenue",
        "renderer": "line",
        "style": { "color": "token.chart.primary", "lineWidth": 3 }
      }
    ],
    "legend": { "visible": false },
    "axes": {
      "x": { "label": "Day" },
      "y": { "label": "Revenue" }
    },
    "tooltip": { "enabled": true, "mode": "nearest" }
  },
  "formatting": {
    "currency": { "code": "USD", "display": "symbol" },
    "number": { "notation": "compact", "maximumFractionDigits": 1 },
    "date": { "granularity": "day" }
  },
  "interactions": {
    "selection": "single",
    "gestures": ["tap", "pan"]
  },
  "theming": {
    "palette": "example-ios",
    "tokens": {
      "token.chart.primary": "#0F766E"
    }
  },
  "accessibility": {
    "chartTitle": "Thirty-day revenue trend",
    "summaryTemplate": "Revenue trend for the last thirty days.",
    "announceOnLoad": true
  },
  "platformOverrides": {
    "ios": { "interpolation": "monotone", "symbolSize": 4 }
  }
}
